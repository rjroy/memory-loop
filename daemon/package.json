{
  "name": "@memory-loop/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": "./src/server.ts",
    "./vault": "./src/vault/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint": "eslint src/",
    "test": "LOG_LEVEL=silent bun test",
    "test:coverage": "LOG_LEVEL=silent bun test --coverage 2>&1 | awk '/^-+\\|/{p=1} p'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.47",
    "@memory-loop/shared": "workspace:*",
    "cron": "^4.4.0",
    "hono": "^4.7.11",
    "minisearch": "^7.1.1",
    "yaml": "^2.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.4",
    "typescript": "^5.7.2"
  }
}
